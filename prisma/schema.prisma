generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum Role {
  ADMIN
  USER
}

enum ReportCategory {
  FASILITAS_INVENTARIS
  IT_ELEKTRONIK
  LABORATORIUM
}

enum ReportSeverity {
  RINGAN
  SEDANG
  BERAT
}

enum ReportStatus {
  MENUNGGU
  DISETUJUI
  DITOLAK
  DIPROSES
  SELESAI
}

model User {
  id           Int      @id @default(autoincrement())
  nama         String
  jabatan      String?
  nip          String?
  activeNip    String?  @unique
  passwordHash String
  role         Role     @default(USER)
  deletedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  reports              Report[]
  passwordResetTokens  PasswordResetToken[]
}

model Report {
  id                  Int            @id @default(autoincrement())
  userId              Int
  kategori            ReportCategory
  namaBarang          String
  lokasi              String
  deskripsi           String
  severity            ReportSeverity
  fotoUrl             String?
  status              ReportStatus   @default(MENUNGGU)
  alasanPenolakan     String?
  assignedTechnician String?
  adminNotes          String?
  completionNotes     String?
  completionPhotoUrl String?
  approvedAt          DateTime?
  rejectedAt          DateTime?
  processedAt         DateTime?
  finishedAt          DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  user                User           @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model RateLimitBucket {
  key       String   @id
  count     Int      @default(1)
  resetAt   DateTime
  updatedAt DateTime @updatedAt
}
