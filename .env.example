# Database connection used by Prisma/MariaDB.
DATABASE_URL="mysql://user:password@localhost:3306/wikas_perbaikan_alat"

# Required. Use a long random value, at least 32 characters.
# Example generator: openssl rand -base64 32
AUTH_SECRET="replace-with-at-least-32-random-bytes"

# Public origin(s) allowed for same-origin mutation requests.
# Use your real production URL, for example:
# APP_ORIGIN="https://perbaikan.example.com"
APP_ORIGIN="http://localhost:3000"

# Required only when running scripts/seed.ts.
SEED_PASSWORD=""
